{
  // ProtoShift-Core opencode 配置模板
  // 使用方法：复制此文件为 opencode.jsonc，填入你的实际值
  //   copy .opencode\\opencode.example.jsonc .opencode\\opencode.jsonc

  // === Provider 配置 ===
  "provider": {
    // 示例：MiniMax Token Plan
    // "minimax": {
    //   "npm": "@ai-sdk/anthropic",
    //   "options": {
    //     "baseURL": "https://api.minimaxi.com/anthropic/v1",
    //     "apiKey": "<YOUR_API_KEY>"
    //   },
    //   "models": {
    //     "MiniMax-M2.7": { "name": "MiniMax-M2.7" }
    //   }
    // }
  },

  "instructions": [
    "AGENTS.md"
  ],

  "default_agent": "protoshift",

  // === MCP 服务器 ===
  // Godot 使用 Coding-Solo/godot-mcp 作为 MCP server。
  // ProtoShift 自带一个本地 MCP server，负责初始化统一模板，并提醒后续保持 GamePackage、测试和文档的双宿主一致性。
  // 不要直接把 Godot 可执行文件当成 MCP server 启动，否则可能出现 UI 被拉起后又退出的行为。
  // 只需把 GODOT_PATH 指向本机 Godot 可执行文件。
  // Unreal 使用 GenOrca/unreal-mcp，自行把仓库克隆到 Unreal 项目的 Plugins 目录后，
  // 再把 UNREAL_MCP_SERVER_DIR 指向其中的 mcp-server 目录。
  "mcp": {
    "protoshift": {
      "type": "local",
      "command": ["node", ".opencode/mcp/protoshift-mcp.mjs"],
      "enabled": true,
      "timeout": 30000
    },
    "godot": {
      "type": "local",
      "command": ["npx", "-y", "@coding-solo/godot-mcp"],
      "environment": {
        "GODOT_PATH": "<ABSOLUTE_GODOT_PATH>"
      },
      "enabled": true,
      "timeout": 30000
    },
    "unreal": {
      "type": "local",
      "command": ["uv", "--directory", "{env:UNREAL_MCP_SERVER_DIR}", "run", "src/unreal_mcp/main.py"],
      "enabled": false,
      "timeout": 30000
    }
  },

  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  }
}
