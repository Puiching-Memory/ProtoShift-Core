{
  "id": "template-hud",
  "name": "Template HUD",
  "theme": {
    "colors": {
      "text": "#FFFFFF"
    },
    "fontSizes": {
      "md": "22"
    },
    "spacing": {
      "md": "16"
    },
    "borderRadii": {
      "sm": "4"
    }
  },
  "root": {
    "id": "root",
    "type": "Stack",
    "style": {
      "width": "100%",
      "height": "100%"
    },
    "children": [
      {
        "id": "status",
        "type": "Text",
        "bindingKey": "statusText",
        "style": {
          "margin": "24",
          "fontSize": "22",
          "textColor": "#FFFFFF"
        }
      },
      {
        "id": "detail",
        "type": "Text",
        "bindingKey": "detailText",
        "style": {
          "margin": "72 24 0 24",
          "fontSize": "18",
          "textColor": "#FFFFFF"
        }
      },
      {
        "id": "hint",
        "type": "Text",
        "bindingKey": "hintText",
        "style": {
          "margin": "112 24 0 24",
          "fontSize": "18",
          "textColor": "#FFFFFF"
        }
      }
    ]
  },
  "bindings": {
    "statusText": {
      "key": "statusText",
      "type": "Text",
      "source": "hud.statusText"
    },
    "detailText": {
      "key": "detailText",
      "type": "Text",
      "source": "hud.detailText"
    },
    "hintText": {
      "key": "hintText",
      "type": "Text",
      "source": "hud.hintText"
    }
  }
}